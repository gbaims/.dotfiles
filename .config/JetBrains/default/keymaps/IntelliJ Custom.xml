<keymap version="1" name="IntelliJ Custom" parent="$default">
  <action id="ActivateBookmarksToolWindow" />
  <action id="ActivateTerminalToolWindow">
    <keyboard-shortcut first-keystroke="alt f12" />
    <keyboard-shortcut first-keystroke="alt 2" />
  </action>
  <action id="CloseContent">
    <keyboard-shortcut first-keystroke="ctrl f4" />
    <keyboard-shortcut first-keystroke="alt w" />
  </action>
  <action id="EditorDown">
    <keyboard-shortcut first-keystroke="down" />
    <keyboard-shortcut first-keystroke="j" />
  </action>
  <action id="EditorLeft">
    <keyboard-shortcut first-keystroke="left" />
    <keyboard-shortcut first-keystroke="h" />
  </action>
  <action id="EditorRight">
    <keyboard-shortcut first-keystroke="right" />
    <keyboard-shortcut first-keystroke="l" />
  </action>
  <action id="EditorUp">
    <keyboard-shortcut first-keystroke="up" />
    <keyboard-shortcut first-keystroke="k" />
  </action>
  <action id="FocusEditor">
    <keyboard-shortcut first-keystroke="escape" />
    <keyboard-shortcut first-keystroke="alt quote" />
  </action>
  <action id="MainMenuButton.ShowMenu" />
  <action id="MaximizeToolWindow">
    <keyboard-shortcut first-keystroke="shift ctrl quote" />
    <keyboard-shortcut first-keystroke="alt escape" />
  </action>
  <action id="NextSplitter">
    <keyboard-shortcut first-keystroke="alt tab" />
  </action>
  <action id="NextTab">
    <keyboard-shortcut first-keystroke="alt right" />
    <keyboard-shortcut first-keystroke="alt e" />
  </action>
  <action id="OpenInRightSplit">
    <keyboard-shortcut first-keystroke="shift enter" />
    <mouse-shortcut keystroke="alt button1 doubleClick" />
    <keyboard-shortcut first-keystroke="ctrl v" />
  </action>
  <action id="PreviousTab">
    <keyboard-shortcut first-keystroke="alt left" />
    <keyboard-shortcut first-keystroke="alt q" />
  </action>
  <action id="SplitVertically">
    <keyboard-shortcut first-keystroke="alt back_slash" />
  </action>
  <action id="Terminal.NewTab">
    <keyboard-shortcut first-keystroke="shift ctrl t" />
    <keyboard-shortcut first-keystroke="alt t" />
  </action>
  <action id="Terminal.SplitVertically">
    <keyboard-shortcut first-keystroke="alt back_slash" />
  </action>
  <action id="Terminal.SwitchFocusToEditor">
    <keyboard-shortcut first-keystroke="alt quote" />
    <keyboard-shortcut first-keystroke="escape" />
  </action>
  <action id="Vcs.Diff.IncludeWholeChangedLinesIntoCommit">
    <keyboard-shortcut first-keystroke="space" />
  </action>
</keymap>